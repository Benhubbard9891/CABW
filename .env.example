# CABW Enterprise - Environment Configuration
# Copy this file to .env and customize for your environment

# Application
ENVIRONMENT=development
DEBUG=true
APP_NAME=CABW Enterprise
APP_VERSION=3.0.0

# Database
DB_URL=postgresql+asyncpg://cabw:cabw@localhost:5432/cabw
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=info
API_CORS_ORIGINS=["*"]

# Authentication
# IMPORTANT: Change this in production!
AUTH_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

# Simulation
SIM_TICK_RATE=1.0
SIM_MAX_TICKS=10000
SIM_MAX_AGENTS=1000
SIM_ENABLE_GOVERNANCE=true
SIM_ENABLE_AUDIT=true

# Celery
CELERY_BROKER_URL=amqp://cabw:cabw@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TIMEZONE=UTC

# Monitoring
MONITORING_ENABLED=true
MONITORING_METRICS_PORT=9090
MONITORING_LOG_LEVEL=INFO
MONITORING_LOG_FORMAT=json
